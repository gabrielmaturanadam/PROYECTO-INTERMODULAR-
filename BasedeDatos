CREATE TABLE profesor (
    id_profesor SERIAL PRIMARY KEY,
    nombre VARCHAR(100) NOT NULL,
    apellido VARCHAR(100) NOT NULL,
    email VARCHAR(150) UNIQUE,
    edad INT,
    rol VARCHAR(20) DEFAULT 'PROFESOR' 
);

CREATE TABLE disciplina (
    id_disciplina SERIAL PRIMARY KEY,
    nombre VARCHAR(100) NOT NULL UNIQUE
);

CREATE TABLE alumno (
    id_alumno SERIAL PRIMARY KEY,
    nombre VARCHAR(100) NOT NULL,
    apellido VARCHAR(100) NOT NULL,
    email VARCHAR(150) UNIQUE,
    telefono VARCHAR(20)
);


CREATE TABLE curso (
    id_curso SERIAL PRIMARY KEY,
    id_disciplina INT NOT NULL,
    nivel VARCHAR(20) CHECK (nivel IN ('BASICO','AVANZADO')),
    id_tutor INT UNIQUE, -- un profesor solo puede ser tutor de un curso

    FOREIGN KEY (id_disciplina) REFERENCES disciplina(id_disciplina),
    FOREIGN KEY (id_tutor) REFERENCES profesor(id_profesor)
);

-- Profesores pueden dar varios cursos
CREATE TABLE profesor_curso (
    id_profesor INT,
    id_curso INT,
    PRIMARY KEY (id_profesor, id_curso),

    FOREIGN KEY (id_profesor) REFERENCES profesor(id_profesor),
    FOREIGN KEY (id_curso) REFERENCES curso(id_curso)
);

-- Un alumno puede estar en varios cursos
CREATE TABLE matricula (
    id_alumno INT,
    id_curso INT,
    fecha_alta DATE DEFAULT CURRENT_DATE,

    PRIMARY KEY (id_alumno, id_curso),

    FOREIGN KEY (id_alumno) REFERENCES alumno(id_alumno),
    FOREIGN KEY (id_curso) REFERENCES curso(id_curso)
);

-- Clases dentro de un curso
CREATE TABLE clase (
    id_clase SERIAL PRIMARY KEY,
    id_curso INT,
    nombre VARCHAR(100),

    FOREIGN KEY (id_curso) REFERENCES curso(id_curso)
);

-- Alumno puede asistir a varias clases
CREATE TABLE alumno_clase (
    id_alumno INT,
    id_clase INT,
    PRIMARY KEY (id_alumno, id_clase),

    FOREIGN KEY (id_alumno) REFERENCES alumno(id_alumno),
    FOREIGN KEY (id_clase) REFERENCES clase(id_clase)
);
